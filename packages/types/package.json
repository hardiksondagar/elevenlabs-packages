{
  "name": "@elevenlabs/types",
  "version": "0.9.0",
  "description": "AsyncAPI contracts and generated TypeScript types for ElevenLabs agent communication",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "generated"
  ],
  "scripts": {
    "generate-types": "tsx ./scripts/generate-all-types.ts && prettier --write ./generated/types/**/*.ts",
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist generated/types",
    "check-types": "tsc --noEmit",
    "lint:es": "eslint . --max-warnings 0"
  },
  "devDependencies": {
    "@asyncapi/cli": "^6.0.0",
    "@asyncapi/modelina": "^5.10.1",
    "@asyncapi/parser": "^3.6.0",
    "@elevenlabs/typescript-config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.20.0",
    "glob": "^11.0.3",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.2"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elevenlabs/packages.git",
    "directory": "packages/types"
  },
  "publishConfig": {
    "access": "public"
  }
}
