{
  "name": "elevenlabs-react-native-example",
  "version": "1.0.8",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "expo start",
    "android": "echo '🚨🚨 Once Expo has started, press `a` 🚨🚨' && node --run dev",
    "ios": "echo '🚨🚨 Once Expo has started, press `i` 🚨🚨' && node --run dev",
    "web": "expo start --web",
    "build:android": "eas build -p android",
    "build:ios": "eas build -p ios",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@elevenlabs/react-native": "workspace:*",
    "@livekit/react-native": "^2.9.6",
    "@livekit/react-native-expo-plugin": "^1.0.1",
    "@livekit/react-native-webrtc": "^137.0.2",
    "expo": "~54.0.31",
    "expo-dev-client": "~6.0.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "~0.21.2",
    "@expo/metro-runtime": "~4.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^20.8.0",
    "@types/react": "~19.1.17",
    "typescript": "^5.5.4"
  }
}
